# AI 模型配置
API_BASE=https://open.bigmodel.cn/api/paas/v4
API_KEY=your_api_key_here

# maimai 封面本地路径（可选，留空则使用在线封面）
LOCAL_COVER_DIR=

# Bot 配置
[bot]
BOT_NAME=结城希亚
COMMAND_START=["", "/"]

# NoneBot 配置
[nonebot]
host=127.0.0.1
port=8888
superusers=["your_qq_number"]

# OneBot 配置
[onebot_v11]
ws_hosts=["ws://127.0.0.1:3001"]

# AI 模型配置
[ai_model]
MODEL_NAME=glm-4-flash
MAX_TOKENS=1024
TEMPERATURE=0.8

# 人设称呼
[yuuki]
creator_name=主人

# 彩迪配置（可选）
parser_bili_ck=
parser_render_type=common
analysis_use_on_message=true

# 可选：Sentry 错误追踪
# SENTRY_DSN=
